# ========================================
# AUTOMATIC IP DETECTION SCRIPT
# ========================================
# This script will automatically detect your local IP
# Run: npm run setup-env
# Or manually: node scripts/setup-env.js

# ========================================
# API CONFIGURATION
# ========================================

# Backend API URL - AUTOMATICALLY CONFIGURED
# The setup script will detect your IP and update this
# For Physical Device: http://YOUR_LOCAL_IP:4000/api
# For Android Emulator: http://10.0.2.2:4000/api
# For iOS Simulator: http://localhost:4000/api
# For Web: http://localhost:4000/api

EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:4000/api

# ========================================
# GOOGLE OAUTH CONFIGURATION
# ========================================

# Get these from Google Cloud Console: https://console.cloud.google.com/
# Go to: APIs & Services > Credentials > Create OAuth 2.0 Client ID

# Android Client ID
EXPO_PUBLIC_ANDROID_CLIENT_ID=your_android_client_id.apps.googleusercontent.com

# iOS Client ID
EXPO_PUBLIC_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com

# Web Client ID (for Expo Go and web testing)
EXPO_PUBLIC_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com

# ========================================
# GOOGLE MAPS CONFIGURATION
# ========================================

# Get this from Google Cloud Console: https://console.cloud.google.com/
# Go to: APIs & Services > Credentials > Create API Key
# Enable: Maps SDK for Android, Maps SDK for iOS, Places API

EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ========================================
# ENVIRONMENT
# ========================================

# Current environment (development, staging, production)
EXPO_PUBLIC_ENV=development

# ========================================
# QUICK SETUP GUIDE
# ========================================

# 1. AUTOMATIC SETUP (Recommended):
#    Run: npm run setup-env
#    This will detect your IP and create .env automatically

# 2. MANUAL SETUP:
#    a. Find your local IP:
#       Windows: ipconfig | findstr IPv4
#       Mac/Linux: ifconfig | grep inet
#    
#    b. Copy this file to .env:
#       cp .env.example .env
#    
#    c. Replace YOUR_LOCAL_IP with your actual IP:
#       EXPO_PUBLIC_API_URL=http://192.168.1.100:4000/api
#    
#    d. Add your Google credentials (optional for now)

# 3. FOR DIFFERENT ENVIRONMENTS:
#    
#    Physical Device (Default):
#    EXPO_PUBLIC_API_URL=http://192.168.1.100:4000/api
#    
#    Android Emulator:
#    EXPO_PUBLIC_API_URL=http://10.0.2.2:4000/api
#    
#    iOS Simulator:
#    EXPO_PUBLIC_API_URL=http://localhost:4000/api
#    
#    Web Browser:
#    EXPO_PUBLIC_API_URL=http://localhost:4000/api

# ========================================
# TROUBLESHOOTING
# ========================================

# If you get "Network Error":
# 1. Check backend is running: cd backend && npm run dev
# 2. Verify IP matches your computer's current IP
# 3. Ensure phone and computer on same WiFi
# 4. Check Windows Firewall allows Node.js
# 5. Try restarting Metro: npx expo start --clear

# If IP changes frequently:
# 1. Set static IP on your computer
# 2. Or run: npm run setup-env (to auto-detect new IP)
